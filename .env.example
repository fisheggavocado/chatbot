OPENAI_API_KEY=your-api-key-here
# 표준 OpenAI 엔드포인트가 아닌 프록시/게이트웨이를 통해 API 토큰을 쓰는 경우에만 설정
OPENAI_BASE_URL=https://your-gateway-endpoint/v1
HF_TOKEN=your-huggingface-token-here
HF_REPO_ID=your-username/your-dataset-name

# HF_TOKEN/HF_REPO_ID가 읽기 전용이라 업로드가 막힐 경우, 쓰기 권한이 있는 별도 repo를 지정하면
# OUTPUT_DIR에서 HF로 올라가는 모든 것(임베딩 인덱스 백업, consultant_bot 체크포인트 백업)이 여기로 간다.
# 설정하지 않으면 업로드 단계를 건너뛴다 (PDF/임베딩 "읽기"는 계속 HF_TOKEN/HF_REPO_ID를 씀).
# HF_TOKEN_ORG=your-write-permission-token-here
# HF_REPO_ID_ORG=your-org/your-dataset-name

# 아래 둘은 선택 사항입니다 (설정하지 않으면 config.py의 기본값 gpt-5-mini / BAAI/bge-m3 사용)
# VISION_MODEL=gpt-5-mini
# EMBEDDING_MODEL=BAAI/bge-m3
