OPENAI_API_KEY=your-api-key-here
# 표준 OpenAI 엔드포인트가 아닌 프록시/게이트웨이를 통해 API 토큰을 쓰는 경우에만 설정
OPENAI_BASE_URL=https://your-gateway-endpoint/v1
HF_TOKEN=your-huggingface-token-here
HF_REPO_ID=your-username/your-dataset-name

# 아래 둘은 선택 사항입니다 (설정하지 않으면 config.py의 기본값 openai/gpt-5-mini / BAAI/bge-m3 사용)
# VISION_MODEL=openai/gpt-5-mini
# EMBEDDING_MODEL=BAAI/bge-m3

# consultant_bot의 외부 트레이싱 대시보드(LangSmith) - 선택 사항. 이 키가 없으면 로컬
# OUTPUT_DIR/traces/{thread_id}.jsonl 트레이스만 남고, 있으면 observability.py가 자동으로 켠다.
# https://smith.langchain.com 에서 발급.
# LANGCHAIN_API_KEY=your-langsmith-api-key-here
# LANGCHAIN_PROJECT=consultant-bot
